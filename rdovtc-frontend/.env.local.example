# ── Local Development ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# .env.local is gitignored and never committed.

# Point to your local backend (php artisan serve runs on 8080 by default)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ── Production ────────────────────────────────────────────────────────────────
# In production, set this in:
#   - Vercel dashboard → Project Settings → Environment Variables, OR
#   - GitHub Secret NEXT_PUBLIC_API_URL (used by the CI workflow)
#
# Production value: https://rdovtc-backend.onrender.com/api
