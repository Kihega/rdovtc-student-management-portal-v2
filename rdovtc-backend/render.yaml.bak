# render.yaml — place in root of rdovtc-backend repo
# Render reads this file to auto-configure your services.

services:
  - type: web
    name: rdovtc-backend
    runtime: docker
    dockerfilePath: ./Dockerfile
    plan: free
    healthCheckPath: /health
    envVars:
      - key: APP_ENV
        value: production
      - key: APP_DEBUG
        value: false
      - key: APP_KEY
        generateValue: true
      - key: APP_URL
        value: https://rdovtc-backend.onrender.com   # update after first deploy

      # Render auto-injects DATABASE_URL when a DB is attached in the dashboard.
      # The pgsql driver in config/database.php reads it automatically.
      - key: DATABASE_URL
        fromDatabase:
          name: rdovtc-db
          property: connectionString

      - key: DB_CONNECTION
        value: pgsql
      - key: DB_SSLMODE
        value: require

      - key: FRONTEND_URL
        value: https://rdovtc-frontend.vercel.app   # update to your Vercel URL

      - key: LOG_CHANNEL
        value: stderr
      - key: CACHE_STORE
        value: database
      - key: SESSION_DRIVER
        value: cookie

# ── Free PostgreSQL database ──────────────────────────────────────────────────
# ⚠️  Free Render PostgreSQL expires every 30 days.
#     After expiry: Render dashboard → delete old DB → create new free DB
#     → the next deploy will auto-run `php artisan migrate --seed`
databases:
  - name: rdovtc-db
    plan: free
    databaseName: rdovtc
    user: rdovtc_user
