APP_NAME="RDO VTC Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: SQLite (easiest for local dev)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

# Option B: Local PostgreSQL (comment out SQLite above and uncomment below)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=rdovtc
# DB_USERNAME=rdovtc_user
# DB_PASSWORD=secret
# DB_SSLMODE=prefer

# ── Session / Cache ───────────────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin — must match what browser sends
FRONTEND_URL=http://localhost:3000

# ── Production only (set in Render dashboard, not here) ───────────────────────
# DATABASE_URL=postgres://...        # Render injects this automatically
# DB_SSLMODE=require
