APP_NAME="RDO VTC Student System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://rdovtc-backend.onrender.com

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — Render Free PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
# Render injects DATABASE_URL automatically when you attach a PostgreSQL DB.
# Laravel reads it via the 'url' key in config/database.php.
# You can also set individual vars below as a fallback.
#
# ⚠️  Render Free PostgreSQL expires every 30 days.
#     After expiry: create a new free DB → update DATABASE_URL → redeploy
#     → run: php artisan migrate --seed   (all data restored in seconds)
#
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rdovtc
DB_USERNAME=rdovtc_user
DB_PASSWORD=

# Render PostgreSQL requires SSL
DB_SSLMODE=require

LOG_CHANNEL=stderr
LOG_LEVEL=error

BROADCAST_CONNECTION=log
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=rdovtc-frontend.vercel.app,localhost:3000
SESSION_DOMAIN=.onrender.com

# CORS — allow Vercel frontend
FRONTEND_URL=https://rdovtc-frontend.vercel.app

MAIL_MAILER=log
